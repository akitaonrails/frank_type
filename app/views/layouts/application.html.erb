<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="min-h-full" data-theme="current">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= javascript_tag nonce: true do %>
      try {
        var frankTypeTheme = window.localStorage.getItem("frankType.theme")
        if (["current", "logo-rush"].includes(frankTypeTheme)) document.documentElement.dataset.theme = frankTypeTheme
      } catch (_error) {}
    <% end %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <% body_controller = ["theme"] %>
  <% body_controller << yield(:body_controller).strip if content_for?(:body_controller) %>
  <% body_data = { controller: body_controller.join(" ") } %>
  <% body_data[:action] = yield(:body_action).strip if content_for?(:body_action) %>
  <% body_data[:typing_excerpts_value] = yield(:typing_excerpts_value).strip if content_for?(:typing_excerpts_value) %>
  <% body_data[:typing_i18n_value] = yield(:typing_i18n_value).strip if content_for?(:typing_i18n_value) %>

  <body class="app-body min-h-full antialiased" <%= tag.attributes(data: body_data) %>>
    <header class="mx-auto grid w-full max-w-7xl grid-cols-[auto_1fr_auto] items-center gap-4 px-4 py-5 sm:px-6 lg:px-8">
      <%= link_to root_path, class: "group inline-flex items-center gap-3" do %>
        <%= image_tag "/logo.png", alt: t("app.name"), class: "logo-shadow size-12 rounded-2xl shadow-lg transition group-hover:rotate-3" %>
        <span>
          <span class="app-title block text-sm font-semibold uppercase tracking-[0.34em]"><%= t("app.name") %></span>
          <span class="app-subtitle block text-xs"><%= t("app.tagline") %></span>
        </span>
      <% end %>

      <div class="hidden min-w-0 justify-center lg:flex">
        <%= yield :header_controls %>
      </div>

      <nav class="nav-shell flex items-center gap-2 text-sm">
        <%= link_to t("app.nav.practice"), root_path, class: "nav-link px-4 py-2" %>
        <%= link_to t("app.nav.profile"), profile_path, class: "nav-link px-4 py-2" %>
        <%= link_to t("app.nav.sources"), sources_path, class: "nav-link hidden px-4 py-2 sm:inline-block" %>
      </nav>
    </header>

    <% if content_for?(:header_controls) %>
      <div class="mx-auto flex w-full max-w-7xl justify-center px-4 pb-3 lg:hidden sm:px-6 lg:px-8">
        <%= yield :header_controls %>
      </div>
    <% end %>

    <main class="mx-auto w-full max-w-7xl px-4 pb-28 pt-4 sm:px-6 sm:pb-20 lg:px-8">
      <%= yield %>
    </main>

    <div class="fixed inset-x-0 bottom-4 z-40 flex justify-center px-4 text-xs">
      <div class="preference-bar inline-flex flex-wrap items-center justify-center gap-1 shadow-2xl backdrop-blur-md">
        <span class="preference-label px-3 py-1"><%= t("app.locale.label") %></span>
        <% [["en", t("app.locale.english")], ["pt-BR", t("app.locale.portuguese")]].each do |locale, label| %>
          <% active = I18n.locale.to_s == locale %>
          <%= link_to label, locale_switch_path(locale), class: "preference-link px-3 py-1.5 font-semibold #{active ? "preference-link-active" : nil}" %>
        <% end %>
        <span class="ui-divider mx-1 h-5 w-px" aria-hidden="true"></span>
        <span class="preference-label px-3 py-1"><%= t("app.theme.label") %></span>
        <% [["current", t("app.theme.current")], ["logo-rush", t("app.theme.logo_rush")]].each do |theme, label| %>
          <button type="button" class="preference-link px-3 py-1.5 font-semibold" data-theme-target="button" data-theme-theme-param="<%= theme %>" data-action="theme#set"><%= label %></button>
        <% end %>
      </div>
    </div>
  </body>
</html>
