<% content_for :title, t("pages.sources.title") %>

<section class="grid gap-8 lg:grid-cols-[24rem_minmax(0,1fr)]">
  <aside class="glass-panel h-fit p-6">
    <p class="text-accent text-sm font-medium uppercase tracking-[0.35em]"><%= t("pages.sources.eyebrow") %></p>
    <h1 class="text-primary mt-3 text-4xl font-black tracking-tight"><%= t("pages.sources.heading") %></h1>
    <p class="text-body mt-4 text-sm leading-6"><%= t("pages.sources.body") %></p>
  </aside>

  <div class="space-y-4">
    <% @excerpts.each do |excerpt| %>
      <article class="glass-panel p-6">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-primary text-2xl font-black"><%= excerpt.title %></h2>
            <p class="text-muted mt-1 text-sm"><%= excerpt.author %> · <%= excerpt.source %></p>
          </div>
          <span class="speed-badge"><%= t("pages.sources.speed_bands.#{excerpt.speed_band}") %></span>
        </div>
        <p class="text-body mt-5"><%= excerpt.normalized_text %></p>
        <p class="text-subtle mt-4 text-xs"><%= excerpt.word_count %> <%= t("pages.sources.words") %> · <%= excerpt.character_count %> <%= t("pages.sources.characters") %> · <%= link_to t("pages.sources.source"), excerpt.source_url, class: "text-accent" %></p>
      </article>
    <% end %>
  </div>
</section>
