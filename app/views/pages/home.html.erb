<% content_for :title, "Practice · Frank Type" %>

<section
  class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem]"
  data-controller="typing"
  data-typing-excerpts-value="<%= json_escape(Typing::ExcerptCatalog.as_json.to_json) %>"
>
  <div class="glass-panel p-5 sm:p-8 lg:p-10">
    <div class="mb-8 flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.35em] text-teal-200">Typing room</p>
        <h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-6xl">Real prose, stripped for speed.</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">Practice on public-domain excerpts normalized into monkeytype-style word streams. Every key event is timed locally with <code class="rounded bg-white/10 px-1.5 py-0.5 text-teal-100">performance.now()</code>.</p>
      </div>

      <div class="flex shrink-0 flex-wrap gap-2" aria-label="Timer length">
        <% [15, 30, 60].each do |seconds| %>
          <button type="button" class="rounded-full border border-white/10 px-4 py-2 text-sm font-semibold text-slate-300 transition hover:border-teal-300/60 hover:text-white" data-action="typing#setDuration" data-typing-duration-param="<%= seconds %>" data-typing-target="durationButton"><%= seconds %>s</button>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
      <div class="metric-card">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-500">wpm</p>
        <p class="mt-2 text-3xl font-black text-white" data-typing-target="wpm">0</p>
      </div>
      <div class="metric-card">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-500">accuracy</p>
        <p class="mt-2 text-3xl font-black text-white"><span data-typing-target="accuracy">100</span><span class="text-lg text-slate-500">%</span></p>
      </div>
      <div class="metric-card">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-500">time</p>
        <p class="mt-2 text-3xl font-black text-white"><span data-typing-target="timeLeft">30</span><span class="text-lg text-slate-500">s</span></p>
      </div>
      <div class="metric-card">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-500">chars</p>
        <p class="mt-2 text-3xl font-black text-white" data-typing-target="progress">0/0</p>
      </div>
    </div>

    <button
      type="button"
      class="mt-8 block w-full rounded-[1.75rem] border border-white/10 bg-slate-950/50 p-5 text-left outline-none ring-teal-300/40 transition focus:ring-4 sm:p-8"
      data-typing-target="typingSurface"
      data-action="click->typing#focus keydown->typing#keydown"
      tabindex="0"
      aria-label="Typing practice area"
    >
      <span class="mb-5 flex flex-wrap items-center justify-between gap-3 text-sm text-slate-400">
        <span data-typing-target="source"></span>
        <span data-typing-target="stateLabel">click here and start typing</span>
      </span>
      <span class="font-mono text-2xl leading-[2.2] tracking-wide text-slate-500 sm:text-3xl lg:text-4xl" data-typing-target="text"></span>
    </button>

    <div class="mt-6 hidden rounded-3xl border border-teal-300/20 bg-teal-300/10 p-5" data-typing-target="results">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-teal-100">Session saved locally</p>
          <p class="mt-2 text-slate-300" data-typing-target="resultSummary"></p>
        </div>
        <%= link_to "See profile", profile_path, class: "rounded-full bg-teal-300 px-5 py-3 text-center text-sm font-black text-slate-950 transition hover:bg-teal-200" %>
      </div>
    </div>
  </div>

  <aside class="space-y-4">
    <div class="glass-panel p-6">
      <h2 class="text-lg font-bold text-white">Shortcuts</h2>
      <dl class="mt-5 space-y-4 text-sm text-slate-300">
        <div class="flex items-center justify-between gap-4"><dt>Restart text</dt><dd class="rounded-lg bg-white/10 px-2 py-1 font-mono text-xs">Tab + Enter</dd></div>
        <div class="flex items-center justify-between gap-4"><dt>New excerpt</dt><dd class="rounded-lg bg-white/10 px-2 py-1 font-mono text-xs">Ctrl + N</dd></div>
        <div class="flex items-center justify-between gap-4"><dt>Restart timer</dt><dd class="rounded-lg bg-white/10 px-2 py-1 font-mono text-xs">Ctrl + R</dd></div>
      </dl>
    </div>

    <div class="glass-panel p-6">
      <h2 class="text-lg font-bold text-white">Local by default</h2>
      <p class="mt-3 text-sm leading-6 text-slate-300">No account is required. Completed sessions, character timings, word timings, WPM, raw WPM, and accuracy are stored in this browser's local storage.</p>
    </div>

    <div class="glass-panel p-6">
      <h2 class="text-lg font-bold text-white">Corpus plan</h2>
      <p class="mt-3 text-sm leading-6 text-slate-300">The seed set uses attributed public-domain excerpts. The ingestion path is Project Gutenberg catalog or Gutendex metadata, cached locally, normalized, and audited before adding excerpts.</p>
      <%= link_to "View sources", sources_path, class: "mt-4 inline-flex text-sm font-semibold text-teal-200 hover:text-teal-100" %>
    </div>
  </aside>
</section>
