<% content_for :title, t("pages.profile.title") %>

<section class="space-y-6" data-controller="profile" data-profile-i18n-value="<%= t("js.profile").to_json %>">
  <div class="text-subtle flex flex-wrap items-center justify-between gap-3 text-xs">
    <p class="text-accent font-medium uppercase tracking-[0.3em]"><%= t("pages.profile.eyebrow") %></p>
    <button type="button" class="danger-button" data-action="profile#clearHistory"><%= t("pages.profile.clear_history") %></button>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="metric-card"><p class="text-subtle text-xs uppercase tracking-[0.24em]"><%= t("pages.profile.metrics.sessions") %></p><p class="text-primary mt-2 text-3xl font-black" data-profile-target="sessionCount">0</p></div>
    <div class="metric-card"><p class="text-subtle text-xs uppercase tracking-[0.24em]"><%= t("pages.profile.metrics.best_wpm") %></p><p class="text-primary mt-2 text-3xl font-black" data-profile-target="bestWpm">0</p></div>
    <div class="metric-card"><p class="text-subtle text-xs uppercase tracking-[0.24em]"><%= t("pages.profile.metrics.average_wpm") %></p><p class="text-primary mt-2 text-3xl font-black" data-profile-target="averageWpm">0</p></div>
    <div class="metric-card"><p class="text-subtle text-xs uppercase tracking-[0.24em]"><%= t("pages.profile.metrics.average_accuracy") %></p><p class="text-primary mt-2 text-3xl font-black"><span data-profile-target="averageAccuracy">0</span><span class="text-subtle text-lg">%</span></p></div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <div class="glass-panel p-6">
      <h2 class="text-primary text-xl font-black"><%= t("pages.profile.charts.wpm_trend") %></h2>
      <canvas class="mt-6 h-72 w-full" data-profile-target="wpmChart" width="720" height="320"></canvas>
    </div>
    <div class="glass-panel p-6">
      <h2 class="text-primary text-xl font-black"><%= t("pages.profile.charts.accuracy_trend") %></h2>
      <canvas class="mt-6 h-72 w-full" data-profile-target="accuracyChart" width="720" height="320"></canvas>
    </div>
  </div>

  <div class="glass-panel p-6">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-primary text-xl font-black"><%= t("pages.profile.recent_sessions") %></h2>
      <%= link_to t("pages.profile.practice"), root_path, class: "surface-button" %>
    </div>
    <div class="table-frame">
      <div class="table-head">
        <span><%= t("pages.profile.table.date") %></span><span><%= t("pages.profile.table.wpm") %></span><span><%= t("pages.profile.table.accuracy") %></span><span><%= t("pages.profile.table.duration") %></span><span><%= t("pages.profile.table.text") %></span>
      </div>
      <div data-profile-target="recentSessions" class="table-body text-sm"></div>
    </div>
  </div>
</section>
